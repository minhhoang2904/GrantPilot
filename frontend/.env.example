# Copy to .env.local and fill in values.
# In dev, all /api/* calls are proxied to localhost:8001 by Vite (see vite.config.ts).
# In production Docker builds, set this to the real backend URL.
VITE_SERVER_B_URL=http://localhost:8001

# "mock" = email text input (default, no Google Cloud setup needed).
# "google" = Google Identity sign-in (requires additional integration in auth.ts).
VITE_AUTH_MODE=mock
