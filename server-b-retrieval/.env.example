# Khong dien secret vao file duoc commit. Copy thanh .env o root hoac export tu shell.
LEGAL_DATA_BACKEND=mongodb
MONGODB_URI=
MONGODB_DATABASE=grantpilot
MONGODB_DOCUMENTS_COLLECTION=legal_documents
MONGODB_LEGAL_UNITS_COLLECTION=legal_units
MONGODB_POLICIES_COLLECTION=policies
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

PINECONE_API_KEY=
PINECONE_INDEX_HOST=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=legal_units

FPT_API_KEY=
FPT_BASE_URL=https://mkp-api.fptcloud.com
FPT_EMBEDDING_MODEL=Vietnamese_Embedding
FPT_RERANK_MODEL=bge-reranker-v2-m3
FPT_QUERY_REWRITE_MODEL=DeepSeek-V4-Flash
FPT_ANSWER_MODEL=GLM-5.2
FPT_QUERY_REWRITE_MAX_TOKENS=512
FPT_ANSWER_MAX_TOKENS=8192
FPT_ANSWER_THINKING=disabled
FPT_ANSWER_REASONING_EFFORT=none

REDIS_URL=redis://localhost:6379/0
CHAT_MEMORY_TTL_SECONDS=86400

SERVER_C_URL=http://localhost:8002
SERVER_C_TIMEOUT_SECONDS=30

# Chi dung khi LEGAL_DATA_BACKEND=jsonl (test/local fallback).
LEGAL_UNITS_PATH=../server-a-ingestion/data/processed/legal_units.jsonl
POLICIES_PATH=../server-a-ingestion/data/policies.json

DENSE_TOP_K=20
BM25_TOP_K=20
FUSION_TOP_K=30
RERANK_TOP_K=5
RRF_K=60
# -1 = tat threshold cho den khi benchmark co du du lieu tune.
RERANK_MIN_SCORE=-1
