# MongoDB Atlas connection string
# Đăng ký tại https://mongodb.com/atlas → tạo cluster → Connect → Drivers
# Thay YOUR_USER, YOUR_PASSWORD, YOUR_CLUSTER bằng thông tin thật
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/
MONGODB_DB=grantpilot
MONGODB_DATABASE=grantpilot

# Local manual services. Docker Compose overrides this with its service hostname.
SERVER_C_URL=http://localhost:8002

# Optional: enables natural-language explanations. Deterministic decisions work without it.
FPT_API_KEY=
FPT_BASE_URL=https://mkp-api.fptcloud.com
FPT_ELIGIBILITY_MODEL=GLM-5.2
FPT_ADVISORY_MODEL=GLM-5.2
FPT_ADVISORY_MAX_TOKENS=1200
FPT_ADVISORY_ENABLED=true
