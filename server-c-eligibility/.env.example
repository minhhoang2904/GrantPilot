# Server C reads only approved, current, decision-eligible policies.
MONGODB_URI=
MONGODB_DATABASE=grantpilot
MONGODB_DOCUMENTS_COLLECTION=legal_documents
MONGODB_LEGAL_UNITS_COLLECTION=legal_units
MONGODB_POLICIES_COLLECTION=policies
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Optional explanation layer. The deterministic engine always owns status.
FPT_API_KEY=
FPT_BASE_URL=https://mkp-api.fptcloud.com
FPT_ELIGIBILITY_MODEL=GLM-5.2
FPT_ELIGIBILITY_MAX_TOKENS=1200
ELIGIBILITY_LLM_ENABLED=true

ELIGIBILITY_TOP_K=10
ELIGIBILITY_MAX_TOP_K=50
STRICT_LEGAL_STATUS=false
